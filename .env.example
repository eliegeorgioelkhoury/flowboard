# Flowboard — environment template. Copy to .env.local and fill in.
# Real secrets live ONLY in host dashboards and GitHub Actions secrets. Never commit .env*.

# ---- Supabase (public, browser-safe) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=change-me-anon-key

# ---- Supabase (server-only, never exposed to the browser) ----
SUPABASE_SERVICE_ROLE_KEY=change-me-server-side-only
