# Flowboard — environment template. Copy to .env.local. Never commit .env*.
# Real secrets live only in host dashboards (Vercel) and GitHub Actions secrets.
#
# Local dev and CI use `supabase start` (a local Supabase stack); its URL and anon
# key are printed by `npx supabase status`. In prod, use your Supabase project's values.

# ---- Supabase (public, browser-safe) ----
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-or-project-anon-key

# ---- Supabase (server-only, never exposed to the browser) ----
SUPABASE_SERVICE_ROLE_KEY=server-side-only
